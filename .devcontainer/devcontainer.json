{
  "name": "Ambiente de Desenvolvimento",
  "dockerComposeFile": ["../docker-compose.yml"],
  "service": "api",
  "workspaceFolder": "/workspace",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true
      },
      "extensions": [
        "prisma.prisma",
        "mikestead.dotenv",
        "usernamehw.errorlens",
        "dbaeumer.vscode-eslint",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian",
        "jeff-hykin.better-dockerfile-syntax",
        "pkief.material-icon-theme",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "rvest.vs-code-prettier-eslint",
        "mylesmurphy.prettify-ts",
        "yoavbls.pretty-ts-errors",
        "inferrinizzard.prettier-sql-vscode",
        "biomejs.biome",
        "hverlin.mise-vscode"
      ]
    }
  },

  "containerEnv": {
    "NODE_ENV": "development",
    "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
    "SSH_AUTH_SOCK": "/tmp/vscode-ssh-auth.sock",

    // Variáveis Personalizadas :
    "SSH_KEY_NAME": "chave_wsl",  // NOTE: Troque pelo nome da sua chave SSH específica
    "GITHUB_USERNAME": "AFSFerreira",    // NOTE: Troque pelo seu nome de usuário no github
    "GITHUB_EMAIL": "alferreira@id.uff.br"     // NOTE: Troque pelo seu email primário do github
  },

  "mounts": [
    "source=${localEnv:HOME}/.ssh/${localEnv:SSH_KEY_NAME:-id_ed25519}.pub,target=/root/.ssh/signing_key.pub,type=bind,readonly"
  ],

  "postCreateCommand": "mise install && corepack enable && corepack prepare pnpm@latest --activate && pnpm install && (yes | pnpm approve-builds) && git config --global user.signingkey /root/.ssh/$SSH_KEY_NAME.pub && git config --global user.email \"$GITHUB_EMAIL\" && git config --global user.name \"$GITHUB_USERNAME\"",
  "remoteUser": "root"
}
