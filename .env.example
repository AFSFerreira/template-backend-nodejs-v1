NODE_ENV="development"
LOG_LEVEL="debug"
PROJECT_NAME="SBAstrobio"

# App:
APP_NAME="SBAstrobio"
APP_PORT=3000
JWT_SECRET=
HASH_SALT_ROUNDS=12
JWT_EXPIRATION="2h"
JWT_REFRESH_EXPIRATION="7d"

# Sentry:
# SENTRY_DSN=

# Comando de inicialização:
COMMAND="npm run start:dev"

# PostgreSQL:
POSTGRES_HOST="localhost"
POSTGRES_USERNAME="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="sbastrobiodb"
POSTGRES_PORT=5432
SCHEMA="public"

# URLs de Conexão:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sbastrobiodb?schema=public"
FRONTEND_URL="http://localhost:5173"

# SMTP:
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_PORT=
SMTP_HOST=
SMTP_SECURE=
