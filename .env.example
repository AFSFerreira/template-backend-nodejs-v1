# Infra:
NODE_ENV=development
LOG_LEVEL=debug
PROJECT_NAME=SBAstrobio

# App:
APP_NAME=SBAstrobio
APP_PORT=3000

# JWT Token:
JWT_SECRET=
# Base64 32 bytes sized token:
ENCRYPTION_KEY=
# Hexadecimal 32 bytes sized token:
BLIND_INDEX_SECRET=

HASH_SALT_ROUNDS=12
JWT_EXPIRATION=2h
JWT_REFRESH_EXPIRATION=7d

# Sentry:
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_URL=
SENTRY_ORG=
SENTRY_PROJECT=

# Comando de inicialização do Dockerfile:
COMMAND=npx prisma migrate deploy && npx prisma generate && node dist/seed.js && npm run start:prod:docker

# Comando de paralelização do Docker Compose file:
COMPOSE_BAKE=true
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
COMPOSE_PARALLEL_BUILD=1

# PostgreSQL:
POSTGRES_CONTAINER_NAME=
POSTGRES_HOST=127.0.0.1
POSTGRES_USERNAME=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=sbastrobiodb
POSTGRES_PORT=5432
SCHEMA=public
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000

# REDIS:
REDIS_CONTAINER_NAME=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# URLs de Conexão:
DATABASE_URL=postgresql://postgres-user:postgres-password@127.0.0.1:5432/sbastrobiodb?schema=public
FRONTEND_URL=http://localhost:5173

# Rate Limiting (per minute):
RATE_LIMIT_STANDARD_MAX=100
RATE_LIMIT_AUTH_MAX=300
RATE_LIMIT_MUTATION_MAX=30
RATE_LIMIT_HEAVY_MAX=10
RATE_LIMIT_CREATE_RESOURCE_MAX=15

# Rate Limiting (per hour):
RATE_LIMIT_AUTH_SECURITY_MAX=75
RATE_LIMIT_AUTH_VALIDATION_MAX=200

# SMTP:
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_PORT=
SMTP_HOST=
SMTP_SECURE=
