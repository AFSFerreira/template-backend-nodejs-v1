NODE_ENV=development
LOG_LEVEL=debug
PROJECT_NAME=SBAstrobio

# App:
APP_NAME=SBAstrobio
APP_PORT=3000
JWT_SECRET=
HASH_SALT_ROUNDS=12
JWT_EXPIRATION=2h
JWT_REFRESH_EXPIRATION=7d

# Comando de inicialização do Dockerfile:
COMMAND=npm run start:prod:docker

# Comando de paralelização do Docker Compose file:
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
COMPOSE_PARALLEL_BUILD=1

# PostgreSQL:
POSTGRES_HOST=localhost
POSTGRES_USERNAME=postgres-user
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=sbastrobiodb
POSTGRES_PORT=5432
SCHEMA=public

# URLs de Conexão:
DATABASE_URL=postgresql://postgres-user:postgres-password@localhost:5432/sbastrobiodb?schema=public
FRONTEND_URL=http://localhost:5173

# SMTP:
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_PORT=
SMTP_HOST=
SMTP_SECURE=
