// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  BLOGGER
  NORMAL_USER
}

enum AuthenticationStatus {
  SUCCESS
  USER_NOT_EXISTS
  INCORRECT_PASSWORD
  BLOCKED
}

enum Occupation {
  RESEARCHER
  PROFESSOR
  STUDENT
  POSTGRADUATE
  MASTER
  DOCTORATE
}

enum EducationLevel {
  ELEMENTARY_SCHOOL
  HIGH_SCHOOL
  UNDERGRADUATE_STUDENT
  BACHELOR
  MASTER_STUDENT
  MASTER
  DOCTORATE_STUDENT
  DOCTORATE
  POSTDOCTORAL_STUDENT
  POSTDOCTORATE
  OTHER
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

enum BlogCategoryType {
  MAIN_CATEGORY
  SUBCATEGORY
}

enum IdentityType {
  CPF
  RNE
  PASSPORT
}

enum PresentationType {
  ORAL
  POSTER
}

enum KeywordType {
  AREA_OF_ACTIVITY
  SUB_AREA_OF_ACTIVITY
  USER_INTEREST
}

model AuthenticationAudit {
  id         Int                  @id @default(autoincrement())
  ipAddress  String?
  remotePort String?
  browser    String?
  status     AuthenticationStatus
  createdAt  DateTime             @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  @@map("authentication_audits")
}

model User {
  id                             Int              @id @default(autoincrement())
  publicId                       String           @unique @default(uuid(7)) @map("public_id")
  fullName                       String           @map("full_name")
  username                       String           @unique
  birthdate                      DateTime
  profileImagePath               String           @map("profile_image_path")
  linkLattes                     String?          @map("link_lattes") // Link externo para o currículo lattes do usuário
  linkGoogleScholar              String?          @map("link_google_scholar") // Link externo para o perfil do usuário no Google Scholar
  linkResearcherId               String?          @map("link_researcherID") // Link externo para o perfil do usuário no ResearcherID
  orcidNumber                    String?          @map("orcid_number") // Número do ORCID do pesquisador
  membershipStatus               MembershipStatus @default(PENDING) @map("membership_status")
  role                           UserRole         @default(NORMAL_USER)
  institutionName                String           @map("institution_name")
  departmentName                 String?          @map("department_name")
  institutionComplement          String?          @map("institution_complement") // Complemento sobre a instituição (nome de laboratório, etc) 
  occupation                     Occupation
  educationLevel                 EducationLevel   @map("education_level")
  identityType                   IdentityType     @map("identity_type")
  identityDocument               String           @map("identity_document")
  emailIsPublic                  Boolean          @map("email_is_public") // Autorização da divulgação do email publicamente no perfil do site
  astrobiologyOrRelatedStartYear Int              @map("astrobiology_or_related_start_year") // Ano em que começou a trabalhar com Astrobiologia ou área correlata (mantido como Int para eventuais queries de comparação) 
  interestDescription            String           @map("interest_description") // Descrição da moticação de participação da comunidade de astrobiologia (limite: 2000 caracteres)
  receiveReports                 Boolean          @map("recieve_reports") // Concordar em receber as Newsletter e informes eventuais da SBA no endereço de e-mail de contato informado.
  publicInformation              String           @map("public_information") // Outras informações públicas (projetos de pesquisa em andamento, outros interesses)
  specificActivity               String           @map("specific_activity") // Área específica de atuação
  specificActivityDescription    String?          @map("specific_activity_description") // Descrição opcional da área caso o usuário marque a alternativa "Other"

  email         String    @unique
  passwordHash  String    @map("password_hash")
  loginAttempts Int       @default(0) @map("login_attempts")
  lastLogin     DateTime? @map("last_login")

  recoveryPasswordToken          String?   @unique @map("recovery_password_token")
  recoveryPasswordTokenExpiresAt DateTime? @map("recovery_password_token_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityAreaId Int     @map("activity_area_id")
  activityArea   Keyword @relation("user_activity_area", fields: [activityAreaId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  address        Address?        @relation()
  enrolledCourse EnrolledCourse? @relation()
  DirectorBoard  DirectorBoard?  @relation()

  AuthenticationAudit AuthenticationAudit[]  @relation()
  AcademicPublication AcademicPublications[] @relation()
  Blog                Blog[]                 @relation()
  UserKeywords        Keyword[]              @relation("user_keywords")
  UserComments        NewsletterComment[]    @relation("comment_author")
  CommentLike         CommentLike[]          @relation("user_likes")

  @@map("users")
}

model Address {
  id       Int    @id @default(autoincrement())
  zip      String
  number   String
  street   String
  district String
  city     String
  state    String
  country  String

  createdAt DateTime @default(now()) @map("created_at")

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("addresses")
}

model EnrolledCourse {
  id                     Int       @id @default(autoincrement())
  courseName             String?   @map("course_name")
  startGraduationDate    DateTime? @map("start_graduation_date") // Formato de retorno: MM/AAAA (mantido como DateTime para facilitar queries de comparação)
  expectedGraduationDate DateTime? @map("expected_graduation_date") // Formato de retorno: MM/AAAA (mantido como DateTime para facilitar queries de comparação)
  supervisorName         String?   @map("supervisor_name")
  scholarshipHolder      Boolean   @map("scholarship_holder") // O usuário é bolsista?
  sponsoringOrganization String?   @map("sponsoring_organization") // Agência / órgão responsável pela bolsa

  createdAt DateTime @default(now()) @map("created_at")

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("enrolled_courses")
}

model AcademicPublications {
  id              Int      @id @default(autoincrement())
  title           String
  authors         String
  publicationDate DateTime @map("publication_date")
  journalName     String   @map("journal_name")
  volume          String
  editionNumber   String   @map("edition_number")
  pageInterval    String   @map("page_interval")
  linkDOI         String   @map("link_DOI")

  createdAt DateTime @default(now()) @map("created_at")

  userId Int  @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("academic_publications")
}

model Keyword {
  id    Int         @id @default(autoincrement())
  value String
  type  KeywordType

  createdAt DateTime @default(now()) @map("created_at")

  UserKeywords     User[] @relation("user_keywords")
  UserActivityArea User[] @relation("user_activity_area")

  @@unique([type, value])
  @@index([value])
  @@index([type])
  @@map("keywords")
}

model DirectorBoard {
  id                        Int    @id @default(autoincrement())
  publicId                  String @unique @default(uuid(7)) @map("public_id")
  directorBoardProfileImage String @map("director_board_profile_image") // NOTE: Por definição, a imagem de directorBoard corresponde à imagem de user
  aboutMe                   String @map("about_me")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("directors_board")
}

model Category {
  id   Int              @id @default(autoincrement())
  name String           @unique
  type BlogCategoryType

  createdAt DateTime @default(now()) @map("created_at")

  BlogSubCategory Blog[] @relation("subcategory_fk")
  Blog            Blog[] @relation("main_category_fk")

  @@map("categories")
}

// NOTE: Somente administradores podem realizar postagens
model Blog {
  id         Int    @id @default(autoincrement())
  publicId   String @unique @default(uuid(7)) @map("public_id")
  authorName String @map("author_name") // Para persistir o nome mesmo após a deleção do usuário
  content    String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mainCategoryId Int      @map("main_category_id")
  mainCategory   Category @relation("main_category_fk", fields: [mainCategoryId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  authorId Int?  @map("author_id")
  author   User? @relation(fields: [authorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  subcategories Category[] @relation("subcategory_fk")

  @@map("blogs")
}

model MeetingParticipation {
  userId    Int
  meetingId Int
  attended  Boolean?

  createdAt DateTime @default(now()) @map("created_at")

  presentation MeetingPresentation? @relation()

  @@id([userId, meetingId])
  @@map("meeting_participations")
}

model MeetingPresentation {
  id               Int              @id @default(autoincrement())
  publicId         String           @unique @default(uuid(7)) @map("public_id")
  presentationType PresentationType
  authors          String
  title            String
  affiliations     String
  description      String
  createdAt        DateTime         @default(now()) @map("created_at")

  userId               Int                  @map("user_id")
  meetingId            Int                  @map("meeting_id")
  meetingParticipation MeetingParticipation @relation(fields: [userId, meetingId], references: [userId, meetingId], onUpdate: Cascade, onDelete: Cascade)

  @@unique([userId, meetingId])
  @@map("meeting_presentations")
}

model Meeting {
  id          Int    @id @default(autoincrement())
  publicId    String @unique @default(uuid(7)) @map("public_id")
  name        String
  image       String
  description String
  location    String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("meetings")
}

model Newsletter {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7)) @map("public_id")
  title    String
  edition  String
  number   String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  NewsletterItems NewsletterItem[] @relation()

  @@unique([edition, number]) // Só existe um número por edição
  @@map("newsletters")
}

model NewsletterItem {
  id         Int    @id @default(autoincrement())
  title      String
  content    String
  image      String
  linkReport String

  newsletterId Int
  Newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("newsletter_items")
}

model NewsletterComment {
  id      Int    @id @default(autoincrement())
  content String

  // Likes em cache pra evitar muitas consultas aninhadas:
  likesQuantity Int @default(0) @map("likes_quantity")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId Int
  User   User @relation("comment_author", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  parentCommentId Int?
  ParentComment   NewsletterComment? @relation("parent_comment", fields: [parentCommentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  ChildComments NewsletterComment[] @relation("parent_comment")

  CommentLike CommentLike[] @relation()

  @@map("comments")
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  userId Int
  User   User @relation("user_likes", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  newsletterCommentId Int
  NewsletterComment   NewsletterComment @relation(fields: [newsletterCommentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("comment_likes")
}
