generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuthenticationAudit {
  id         Int                      @id @default(autoincrement())
  ipAddress  String?                  @map("ip_address") @db.Inet
  remotePort String?                  @map("remote_port")
  browser    String?
  status     AuthenticationStatusType
  createdAt  DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  userId     Int?                     @map("user_id")
  user       User?                    @relation(fields: [userId], references: [id])

  @@map("authentication_audits")
}

model User {
  id                             Int                      @id @default(autoincrement())
  publicId                       String                   @unique @default(uuid(7)) @map("public_id")
  fullName                       String                   @map("full_name")
  username                       String                   @unique
  birthdate                      DateTime                 @db.Date
  profileImage                   String                   @map("profile_image")
  linkLattes                     String?                  @map("link_lattes")
  linkGoogleScholar              String?                  @map("link_google_scholar")
  linkResearcherId               String?                  @map("link_researcher_id")
  orcidNumber                    String?                  @map("orcid_number")
  membershipStatus               MembershipStatusType     @default(PENDING) @map("membership_status")
  role                           UserRoleType             @default(DEFAULT)
  departmentName                 String?                  @map("department_name")
  institutionComplement          String?                  @map("institution_complement")
  occupation                     OccupationType?
  educationLevel                 EducationLevelType       @map("education_level")
  identityType                   IdentityType             @map("identity_type")
  identityDocument               String                   @map("identity_document")
  emailIsPublic                  Boolean                  @map("email_is_public")
  astrobiologyOrRelatedStartYear Int?                     @map("astrobiology_or_related_start_year")
  interestDescription            String                   @map("interest_description")
  receiveReports                 Boolean                  @map("receive_reports")
  publicInformation              String?                  @map("public_information")
  activityAreaDescription        String?                  @map("activity_area_description")
  subActivityAreaDescription     String?                  @map("sub_activity_area_description")
  email                          String                   @unique
  secondaryEmail                 String?                  @unique @map("secondary_email")
  passwordHash                   String                   @map("password_hash")
  loginAttempts                  Int                      @default(0) @map("login_attempts")
  lastLogin                      DateTime?                @map("last_login") @db.Timestamptz(3)
  recoveryPasswordTokenHash      String?                  @unique @map("recovery_password_token")
  recoveryPasswordTokenExpiresAt DateTime?                @map("recovery_password_token_expires_at") @db.Timestamptz(3)
  createdAt                      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  activityAreaId                 Int?                     @map("activity_area_id")
  subActivityAreaId              Int?                     @map("sub_activity_area_id")
  institutionId                  Int?                     @map("institution_id")
  fullNameTsvPt                  Unsupported("tsvector")? @map("full_name_tsv_pt")
  fullNameUnaccent               String?                  @default(dbgenerated("immutable_unaccent(SUBSTRING(COALESCE(full_name, ''::text) FROM 1 FOR 255))")) @map("full_name_unaccent")
  AcademicPublication            AcademicPublication[]
  Address                        Address?
  AuthenticationAudit            AuthenticationAudit[]
  Blog                           Blog[]
  CommentLike                    CommentLike[]
  NewsletterComment              NewsletterComment[]
  DirectorBoard                  DirectorBoard?
  EnrolledCourse                 EnrolledCourse?
  MeetingParticipation           MeetingParticipation[]
  ActivityArea                   ActivityArea?            @relation("activity_area", fields: [activityAreaId], references: [id], onDelete: NoAction)
  Institution                    Institution?             @relation(fields: [institutionId], references: [id], onDelete: NoAction)
  SubActivityArea                ActivityArea?            @relation("sub_activity_area", fields: [subActivityAreaId], references: [id], onDelete: NoAction)
  Keyword                        Keyword[]                @relation("KeywordToUser")

  @@unique([identityType, identityDocument])
  @@index([membershipStatus])
  @@index([fullNameTsvPt], map: "idx_users_full_name_tsv_pt", type: Gin)
  @@index([fullNameUnaccent(ops: raw("gin_trgm_ops"))], map: "idx_users_fullname_trgm_gin", type: Gin)
  @@map("users")
}

model Address {
  id         Int          @id @default(autoincrement())
  zip        String
  number     String
  street     String
  district   String
  city       String
  stateId    Int          @map("state_id")
  State      AddressState @relation(fields: [stateId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  complement String?
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  userId     Int          @unique @map("user_id")
  User       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stateId])
  @@index([userId])
  @@map("addresses")
}

model AddressState {
  id        Int    @id @default(autoincrement())
  name      String
  countryId Int    @map("country_id")

  Country   AddressCountry @relation(fields: [countryId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)

  Address Address[]

  @@unique([name, countryId])
  @@map("address_states")
}

model AddressCountry {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  State AddressState[] @relation()

  @@index([name])
  @@map("address_countries")
}

model EnrolledCourse {
  id                     Int       @id @default(autoincrement())
  courseName             String?   @map("course_name")
  startGraduationDate    DateTime? @map("start_graduation_date") @db.Date
  expectedGraduationDate DateTime? @map("expected_graduation_date") @db.Date
  supervisorName         String?   @map("supervisor_name")
  scholarshipHolder      Boolean   @map("scholarship_holder")
  sponsoringOrganization String?   @map("sponsoring_organization")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  userId                 Int       @unique @map("user_id")
  User                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("enrolled_courses")
}

model AcademicPublication {
  id                         Int                         @id @default(autoincrement())
  title                      String
  publicationYear            Int                         @map("publication_year")
  journalName                String                      @map("journal_name")
  volume                     String
  editionNumber              String                      @map("edition_number")
  startPage                  String                      @map("start_page")
  linkDoi                    String                      @map("link_doi")
  createdAt                  DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  userId                     Int                         @map("user_id")
  activityAreaId             Int                         @map("activity_area_id")
  titleTsvPt                 Unsupported("tsvector")?    @map("title_tsv_pt")
  titleUnaccent              String?                     @default(dbgenerated("immutable_unaccent(SUBSTRING(COALESCE(title, ''::text) FROM 1 FOR 255))")) @map("title_unaccent")
  AcademicPublicationAuthors AcademicPublicationAuthor[]
  ActivityArea               ActivityArea                @relation(fields: [activityAreaId], references: [id], onDelete: NoAction)
  User                       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([titleUnaccent(ops: raw("gin_trgm_ops"))], map: "idx_academic_publications_title_trgm_gin", type: Gin)
  @@index([titleTsvPt], map: "idx_academic_publications_title_tsv_pt", type: Gin)
  @@map("academic_publications")
}

model AcademicPublicationAuthor {
  id                    Int                 @id @default(autoincrement())
  publicId              String              @unique @default(uuid(7)) @map("public_id")
  name                  String
  academicPublicationId Int                 @map("academic_publication_id")
  AcademicPublication   AcademicPublication @relation(fields: [academicPublicationId], references: [id], onDelete: Cascade)

  @@unique([academicPublicationId, name])
  @@map("academic_publication_authors")
}

model Institution {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique @default(uuid(7)) @map("public_id")
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  User      User[]

  @@map("institutions")
}

model ActivityArea {
  id                  Int                   @id @default(autoincrement())
  area                String
  type                ActivityAreaType
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  AcademicPublication AcademicPublication[]
  UserActivityArea    User[]                @relation("activity_area")
  UserSubActivityArea User[]                @relation("sub_activity_area")
  BlogSubCategory     Blog[]                @relation("blog_subcategories")

  @@unique([type, area])
  @@map("area_of_activity")
}

model Keyword {
  id        Int      @id @default(autoincrement())
  value     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  User      User[]   @relation("KeywordToUser")

  @@map("keywords")
}

model DirectorBoard {
  id                        Int              @id @default(autoincrement())
  directorPositionId        Int              @unique @map("director_position_id")
  directorBoardProfileImage String           @map("director_board_profile_image")
  aboutMe                   String           @map("about_me")
  createdAt                 DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                 DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  userId                    Int              @unique @map("user_id")
  DirectorPosition          DirectorPosition @relation(fields: [directorPositionId], references: [id], onDelete: NoAction)
  User                      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("directors_board")
}

model DirectorPosition {
  id            Int            @id @default(autoincrement())
  publicId      String         @unique @default(uuid(7)) @map("public_id")
  position      String         @unique
  precedence    Int
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  DirectorBoard DirectorBoard?

  @@map("director_positions")
}

model PaymentInfo {
  id                 Int                  @id @default(1) @db.SmallInt
  pixKey             String               @map("pix_key")
  bank               String
  code               String
  agency             String
  account            String
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  MeetingPaymentInfo MeetingPaymentInfo[]

  @@map("payment_info")
}

model MeetingPaymentInfo {
  id            Int         @id @default(autoincrement())
  value         Decimal     @db.Decimal(10, 2)
  limitDate     DateTime    @map("limit_date") @db.Date
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  paymentInfoId Int         @map("payment_info_id")
  meetingId     Int         @unique @map("meeting_id")
  Meeting       Meeting     @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  PaymentInfo   PaymentInfo @relation(fields: [paymentInfoId], references: [id])

  @@index([meetingId])
  @@map("meeting_payment_information")
}

model MeetingGuest {
  id                   Int                    @id @default(autoincrement())
  fullName             String                 @map("full_name")
  email                String
  institutionName      String                 @map("institution_name")
  departmentName       String                 @map("department_name")
  occupation           OccupationType
  educationLevel       EducationLevelType     @map("education_level")
  wantsNewsletter      Boolean                @map("wants_newsletter")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  MeetingParticipation MeetingParticipation[]

  @@map("meeting_guest")
}

model MeetingParticipation {
  id           Int                  @id @default(autoincrement())
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  userId       Int?                 @map("user_id")
  guestId      Int?                 @map("guest_id")
  meetingId    Int                  @map("meeting_id")
  Guest        MeetingGuest?        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  Meeting      Meeting              @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  User         User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  Presentation MeetingPresentation?

  @@unique([meetingId, userId])
  @@unique([meetingId, guestId])
  @@map("meeting_participants")
}

model MeetingPresentation {
  id                   Int                              @id @default(autoincrement())
  presentationType     PresentationType                 @map("presentation_type")
  title                String
  description          String
  createdAt            DateTime                         @default(now()) @map("created_at") @db.Timestamptz(3)
  participationId      Int                              @unique @map("participation_id")
  Affiliations         MeetingPresentationAffiliation[]
  Authors              MeetingPresentationAuthor[]
  MeetingParticipation MeetingParticipation             @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@map("meeting_presentations")
}

model MeetingPresentationAuthor {
  id             Int                 @id @default(autoincrement())
  name           String
  presentationId Int                 @map("presentation_id")
  Presentation   MeetingPresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@map("meeting_presentation_authors")
}

model MeetingPresentationAffiliation {
  id             Int                 @id @default(autoincrement())
  name           String
  presentationId Int                 @map("presentation_id")
  Presentation   MeetingPresentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@map("meeting_presentation_affiliations")
}

model Meeting {
  id                   Int                    @id @default(autoincrement())
  publicId             String                 @unique @default(uuid(7)) @map("public_id")
  title                String
  image                String
  description          String
  location             String
  lastDate             DateTime               @map("last_date") @db.Date
  participantsCount    Int                    @default(0) @map("participants_count")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  MeetingDate          MeetingDate[]
  MeetingParticipation MeetingParticipation[]
  MeetingPaymentInfo   MeetingPaymentInfo?

  @@index([lastDate])
  @@map("meetings")
}

model MeetingDate {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  meetingId Int      @map("meeting_id")
  Meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_date")
}

model Blog {
  id              Int                      @id @default(autoincrement())
  publicId        String                   @unique @default(uuid(7)) @map("public_id")
  editorialStatus EditorialStatus          @default(PENDING_APPROVAL) @map("editorial_status")
  title           String
  bannerImage     String                   @map("banner_image")
  authorName      String                   @map("author_name")
  accessCount     Int                      @default(0) @map("access_count")
  content         Json                     @db.Json // Conteúdo em prose mirror do Blog
  searchContent   String                   @map("search_content")
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  userId          Int?                     @map("user_id")
  searchTsvPt     Unsupported("tsvector")? @map("search_tsv_pt")
  titleUnaccent   String?                  @default(dbgenerated("immutable_unaccent(SUBSTRING(COALESCE(title, ''::text) FROM 1 FOR 255))")) @map("title_unaccent")
  User            User?                    @relation(fields: [userId], references: [id])
  Subcategories   ActivityArea[]           @relation("blog_subcategories")

  @@index([editorialStatus])
  @@index([searchTsvPt], map: "idx_blogs_search_tsv_pt", type: Gin)
  @@index([titleUnaccent(ops: raw("gin_trgm_ops"))], map: "idx_blogs_title_trgm_gin", type: Gin)
  @@map("blogs")
}

model Newsletter {
  id                Int                 @id @default(autoincrement())
  publicId          String              @unique @default(uuid(7)) @map("public_id")
  title             String
  sequenceNumber    String              @unique @map("sequence_number") // Número absoluto de sequência
  editionNumber     String              @map("edition_number") // Número de edição do ano
  volume            String // Ano de publicação
  content           String              @db.Text // conteúdo em HTML da Newsletter
  commentsQuantity  Int                 @default(0) @map("comments_quantity")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  NewsletterComment NewsletterComment[]

  @@unique([volume, editionNumber])
  @@index([editionNumber])
  @@map("newsletters")
}

model NewsletterComment {
  id              Int                 @id @default(autoincrement())
  content         String
  authorName      String              @map("author_name")
  likesQuantity   Int                 @default(0) @map("likes_quantity")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  newsletterId    Int                 @map("newsletter_id")
  userId          Int?                @map("user_id")
  parentCommentId Int?                @map("parent_comment_id")
  CommentLike     CommentLike[]
  Newsletter      Newsletter          @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  ParentComment   NewsletterComment?  @relation("parent_comment", fields: [parentCommentId], references: [id], onDelete: Cascade)
  ChildComments   NewsletterComment[] @relation("parent_comment")
  User            User?               @relation(fields: [userId], references: [id])

  @@index([newsletterId])
  @@map("comments")
}

model CommentLike {
  id                  Int               @id @default(autoincrement())
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  userId              Int?              @map("user_id")
  newsletterCommentId Int               @map("newsletter_comment_id")
  NewsletterComment   NewsletterComment @relation(fields: [newsletterCommentId], references: [id], onDelete: Cascade)
  User                User?             @relation(fields: [userId], references: [id])

  @@index([newsletterCommentId])
  @@map("comment_likes")
}

model CarouselBanner {
  id         Int      @id @default(autoincrement())
  publicId   String   @unique @default(uuid(7)) @map("public_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  image      String
  link       String?
  precedence Int      @unique @default(0)

  @@map("carousel_banners")
}

enum UserRoleType {
  ADMIN
  MANAGER
  CONTENT_LEADER
  CONTENT_PRODUCER
  DEFAULT
}

enum AuthenticationStatusType {
  SUCCESS
  USER_NOT_EXISTS
  INCORRECT_PASSWORD
  BLOCKED
}

enum OccupationType {
  RESEARCHER
  PROFESSOR
  STUDENT
  POSTGRADUATE
  MASTER
  DOCTORATE
}

enum EducationLevelType {
  ELEMENTARY_SCHOOL
  HIGH_SCHOOL
  UNDERGRADUATE_STUDENT
  BACHELOR
  MASTER_STUDENT
  MASTER
  DOCTORATE_STUDENT
  DOCTORATE
  POST_DOCTORATE_STUDENT
  POST_DOCTORATE
  OTHER
}

enum MembershipStatusType {
  ACTIVE
  INACTIVE
  PENDING
}

enum IdentityType {
  CPF
  RNE
  PASSPORT
}

enum PresentationType {
  ORAL
  POSTER
}

enum ActivityAreaType {
  AREA_OF_ACTIVITY
  SUB_AREA_OF_ACTIVITY
}

enum EditorialStatus {
  PENDING_APPROVAL
  PUBLISHED
  // DRAFT
  // APPROVED
  // CHANGES_REQUESTED
  // ARCHIVED
}
