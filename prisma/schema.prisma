// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model AuthenticationAudit {
  id         Int                      @id @default(autoincrement())
  ipAddress  String?                  @map("ip_address")
  remotePort String?                  @map("remote_port")
  browser    String?
  status     AuthenticationStatusType
  createdAt  DateTime                 @default(now()) @map("created_at")

  userId Int?  @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("authentication_audits")
}

model User {
  id                             Int                  @id @default(autoincrement())
  publicId                       String               @unique @default(uuid(7)) @map("public_id")
  fullName                       String               @map("full_name")
  username                       String               @unique
  birthdate                      DateTime
  profileImage                   String               @map("profile_image")
  linkLattes                     String?              @map("link_lattes")
  linkGoogleScholar              String?              @map("link_google_scholar")
  linkResearcherId               String?              @map("link_researcher_id")
  orcidNumber                    String?              @map("orcid_number")
  membershipStatus               MembershipStatusType @default(PENDING) @map("membership_status")
  role                           UserRoleType         @default(DEFAULT)
  departmentName                 String?              @map("department_name")
  institutionComplement          String?              @map("institution_complement")
  occupation                     OccupationType?
  educationLevel                 EducationLevelType   @map("education_level")
  identityType                   IdentityType         @map("identity_type")
  identityDocument               String               @map("identity_document")
  emailIsPublic                  Boolean              @map("email_is_public")
  astrobiologyOrRelatedStartYear Int?                 @map("astrobiology_or_related_start_year")
  interestDescription            String               @map("interest_description")
  receiveReports                 Boolean              @map("receive_reports")
  publicInformation              String?              @map("public_information")
  activityAreaDescription        String?              @map("activity_area_description")
  subActivityAreaDescription     String?              @map("sub_activity_area_description")

  email         String    @unique
  passwordHash  String    @map("password_hash")
  loginAttempts Int       @default(0) @map("login_attempts")
  lastLogin     DateTime? @map("last_login")

  recoveryPasswordTokenHash      String?   @unique @map("recovery_password_token")
  recoveryPasswordTokenExpiresAt DateTime? @map("recovery_password_token_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityAreaId Int?          @map("activity_area_id")
  ActivityArea   ActivityArea? @relation("activity_area", fields: [activityAreaId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  subActivityAreaId Int?          @map("sub_activity_area_id")
  SubActivityArea   ActivityArea? @relation("sub_activity_area", fields: [subActivityAreaId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  institutionId Int?         @map("institution_id")
  Institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  Address        Address?        @relation()
  EnrolledCourse EnrolledCourse? @relation()
  DirectorBoard  DirectorBoard?  @relation()

  AuthenticationAudit AuthenticationAudit[]  @relation()
  AcademicPublication AcademicPublications[] @relation()
  Blog                Blog[]                 @relation()
  Keyword             Keyword[]              @relation()
  NewsletterComment   NewsletterComment[]    @relation()
  CommentLike         CommentLike[]          @relation()
  UserMeeting         UserMeeting[]          @relation()

  @@unique([identityType, identityDocument])
  @@index([membershipStatus])
  @@map("users")
}

model Address {
  id         Int     @id @default(autoincrement())
  zip        String
  number     String
  street     String
  district   String
  city       String
  state      String
  country    String
  complement String?

  createdAt DateTime @default(now()) @map("created_at")

  userId Int  @unique @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([state])
  @@index([userId])
  @@map("addresses")
}

model EnrolledCourse {
  id                     Int       @id @default(autoincrement())
  courseName             String?   @map("course_name")
  startGraduationDate    DateTime? @map("start_graduation_date")
  expectedGraduationDate DateTime? @map("expected_graduation_date")
  supervisorName         String?   @map("supervisor_name")
  scholarshipHolder      Boolean   @map("scholarship_holder")
  sponsoringOrganization String?   @map("sponsoring_organization")

  createdAt DateTime @default(now()) @map("created_at")

  userId Int  @unique @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("enrolled_courses")
}

model AcademicPublications {
  id              Int    @id @default(autoincrement())
  title           String
  authors         String
  publicationYear Int    @map("publication_year")
  journalName     String @map("journal_name")
  volume          String
  editionNumber   String @map("edition_number")
  startPage       String @map("start_page")
  linkDoi         String @map("link_doi")

  createdAt DateTime @default(now()) @map("created_at")

  userId Int  @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  activityAreaId Int          @map("activity_area_id")
  ActivityArea   ActivityArea @relation(fields: [activityAreaId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  @@index([userId])
  @@map("academic_publications")
}

model Institution {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7)) @map("public_id")
  name     String @unique

  createdAt DateTime @default(now()) @map("created_at")

  User User[] @relation()

  @@map("institutions")
}

model ActivityArea {
  id   Int              @id @default(autoincrement())
  area String
  type ActivityAreaType

  createdAt DateTime @default(now()) @map("created_at")

  UserActivityArea    User[] @relation("activity_area")
  UserSubActivityArea User[] @relation("sub_activity_area")

  Blog            Blog[] @relation("main_blog_category")
  BlogSubCategory Blog[] @relation("blog_subcategories")

  AcademicPublications AcademicPublications[] @relation()

  @@unique([type, area])
  @@map("area_of_activity")
}

model Keyword {
  id    Int    @id @default(autoincrement())
  value String @unique

  createdAt DateTime @default(now()) @map("created_at")

  User User[] @relation()

  @@map("keywords")
}

model DirectorBoard {
  id                        Int    @id @default(autoincrement())
  publicId                  String @unique @default(uuid(7)) @map("public_id")
  directorBoardProfileImage String @map("director_board_profile_image")
  aboutMe                   String @map("about_me")
  position                  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId Int  @unique @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@map("directors_board")
}

model PaymentInfo {
  id      Int    @id @default(1) // Singleton Table
  pixKey  String @map("pix_key")
  bank    String
  code    String
  agency  String
  account String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  MeetingPaymentInfo MeetingPaymentInfo[] @relation()

  @@map("payment_info")
}

model MeetingPaymentInfo {
  id        Int      @id @default(autoincrement())
  value     Decimal  @db.Decimal(10, 2)
  limitDate DateTime @map("limit_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  paymentInfoId Int         @map("payment_info_id")
  PaymentInfo   PaymentInfo @relation(fields: [paymentInfoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  meetingId Int     @unique @map("meeting_id")
  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([meetingId])
  @@map("payment_information")
}

model UserMeeting {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  Presentation MeetingPresentation? @relation()

  userId Int  @map("user_id")
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  meetingId Int     @map("meeting_id")
  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, meetingId])
  @@map("user_meeting")
}

model MeetingPresentation {
  id               Int              @id @default(autoincrement())
  publicId         String           @unique @default(uuid(7)) @map("public_id")
  presentationType PresentationType @map("presentation_type")
  authors          String
  title            String
  affiliations     String
  description      String
  createdAt        DateTime         @default(now()) @map("created_at")

  guestPresenterName  String? @map("guest_presenter_name")
  guestPresenterEmail String? @map("guest_presenter_email")

  userId               Int         @map("user_id")
  meetingId            Int         @map("meeting_id")
  MeetingParticipation UserMeeting @relation(fields: [userId, meetingId], references: [userId, meetingId], onUpdate: Cascade, onDelete: Cascade)

  @@unique([userId, meetingId])
  @@map("meeting_presentations")
}

model Meeting {
  id                Int      @id @default(autoincrement())
  publicId          String   @unique @default(uuid(7)) @map("public_id")
  name              String
  image             String
  description       String
  location          String
  lastDate          DateTime @map("last_date")
  participantsCount Int      @default(0) @map("participants_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  UserMeeting        UserMeeting[]       @relation()
  MeetingDate        MeetingDate[]       @relation()
  MeetingPaymentInfo MeetingPaymentInfo? @relation()

  @@index([lastDate])
  @@map("meetings")
}

model MeetingDate {
  id        Int      @id @default(autoincrement())
  date      DateTime
  createdAt DateTime @default(now()) @map("created_at")

  meetingId Int     @map("meeting_id")
  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([meetingId])
  @@map("meeting_date")
}

model Blog {
  id         Int    @id @default(autoincrement())
  publicId   String @unique @default(uuid(7)) @map("public_id")
  title      String
  authorName String @map("author_name")

  content       Json   @db.Json // ProseMirror Json
  searchContent String @map("search_content") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mainBlogCategoryId Int          @map("main_blog_category_id")
  MainBlogCategory   ActivityArea @relation("main_blog_category", fields: [mainBlogCategoryId], references: [id], onDelete: NoAction, onUpdate: Cascade)

  userId Int?  @map("user_id")
  User   User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  Subcategories ActivityArea[] @relation("blog_subcategories")

  @@index([mainBlogCategoryId])
  @@map("blogs")
}

model Newsletter {
  id       Int    @id @default(autoincrement())
  publicId String @unique @default(uuid(7)) @map("public_id")
  title    String
  edition  String
  number   String

  commentsQuantity Int @default(0) @map("comments_quantity")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  NewsletterItem    NewsletterItem[]    @relation()
  NewsletterComment NewsletterComment[] @relation()

  @@unique([edition, number])
  @@map("newsletters")
}

model NewsletterItem {
  id         Int    @id @default(autoincrement())
  title      String
  content    String
  image      String
  linkReport String @map("link_report")

  createdAt DateTime @default(now()) @map("created_at")

  newsletterId Int        @map("newsletter_id")
  Newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([newsletterId])
  @@map("newsletter_items")
}

model NewsletterComment {
  id         Int    @id @default(autoincrement())
  content    String
  authorName String @map("author_name")

  likesQuantity Int @default(0) @map("likes_quantity")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  newsletterId Int        @map("newsletter_id")
  Newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  userId Int?  @map("user_id")
  User   User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  parentCommentId Int?               @map("parent_comment_id")
  ParentComment   NewsletterComment? @relation("parent_comment", fields: [parentCommentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  ChildComments NewsletterComment[] @relation("parent_comment")

  CommentLike CommentLike[] @relation()

  @@index([newsletterId])
  @@map("comments")
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  userId Int?  @map("user_id")
  User   User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  newsletterCommentId Int               @map("newsletter_comment_id")
  NewsletterComment   NewsletterComment @relation(fields: [newsletterCommentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([newsletterCommentId])
  @@map("comment_likes")
}

enum UserRoleType {
  ADMIN
  MANAGER
  CONTENT_LEADER
  CONTENT_PRODUCER
  DEFAULT
}

enum AuthenticationStatusType {
  SUCCESS
  USER_NOT_EXISTS
  INCORRECT_PASSWORD
  BLOCKED
}

enum OccupationType {
  RESEARCHER
  PROFESSOR
  STUDENT
  POSTGRADUATE
  MASTER
  DOCTORATE
}

enum EducationLevelType {
  ELEMENTARY_SCHOOL
  HIGH_SCHOOL
  UNDERGRADUATE_STUDENT
  BACHELOR
  MASTER_STUDENT
  MASTER
  DOCTORATE_STUDENT
  DOCTORATE
  POST_DOCTORATE_STUDENT
  POST_DOCTORATE
  OTHER
}

enum MembershipStatusType {
  ACTIVE
  INACTIVE
  PENDING
  REJECTED
}

enum IdentityType {
  CPF
  RNE
  PASSPORT
}

enum PresentationType {
  ORAL
  POSTER
}

enum ActivityAreaType {
  AREA_OF_ACTIVITY
  SUB_AREA_OF_ACTIVITY
}
