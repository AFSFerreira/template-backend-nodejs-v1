{
  "name": "astrobiologia-backend",
  "version": "1.0.0",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "build": "tsup src --minify",
    "start:dev": "tsx watch --env-file=.env --no-deprecation src/server.ts",
    "start:prod": "node --env-file=.env dist/server.js",
    "husky": "husky",
    "husky:install": "husky install",
    "format:src": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'src/**/*.{js,ts,tsx,jsx}'",
    "format:prisma": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'prisma/**/*.{js,ts,tsx,jsx}'",
    "lint:src": "eslint src/**/*.{js,ts,tsx,jsx}",
    "lint:prisma": "eslint prisma/**/*.{js,ts,tsx,jsx}",
    "lint:fix:src": "eslint --fix src/**/*.{js,ts,tsx,jsx}",
    "lint:fix:prisma": "eslint --fix prisma/**/*.{js,ts,tsx,jsx}",
    "db:extension:pg-trgm": "prisma db execute --file=prisma/extensions/pg-trgm.sql --schema=prisma/schema.prisma",
    "db:extension:init": "npm run db:extension:pg-trgm",
    "db:shadow:create": "prisma db execute --file=prisma/shadow/create-shadow-db.sql --schema=prisma/schema.prisma",
    "db:shadow:delete": "prisma db execute --file=prisma/shadow/delete-shadow-db.sql --schema=prisma/schema.prisma",
    "db:shadow:init": "npm run db:shadow:delete && npm run db:shadow:create",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force --skip-seed",
    "db:seed": "prisma db seed",
    "db:reset:all": "rimraf prisma/migrations && npm run db:shadow:init && npm run db:migrate:reset && npm run db:migrate:dev:default && npm run db:extension:init && npm run db:seed",
    "db:deploy": "db:shadow:init && prisma migrate deploy && npm run db:extension:init",
    "ci:lint": "npm run lint:fix:prisma && npm run lint:fix:src",
    "ci:format": "npm run format:prisma && npm run format:src"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "19.8.1",
    "@types/bytes": "3.1.5",
    "@types/fs-extra": "11.0.4",
    "@types/json2csv": "5.0.7",
    "@types/jsonwebtoken": "9.0.9",
    "@types/multer": "1.4.13",
    "@types/node": "22.13.9",
    "@types/nodemailer": "6.4.17",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "commitlint": "19.8.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-config-standard-with-typescript": "43.0.1",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-promise": "6.1.1",
    "eslint-plugin-unicorn": "51.0.1",
    "husky": "9.0.11",
    "prettier": "3.2.5",
    "prettier-plugin-prisma": "5.0.0",
    "prisma": "6.13.0",
    "rimraf": "6.0.1",
    "ts-node": "10.9.2",
    "tsup": "8.4.0",
    "tsx": "4.19.3",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.0.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.0.3",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "8.2.0",
    "@prisma/client": "6.13.0",
    "bcryptjs": "3.0.2",
    "bytes": "3.1.2",
    "cpf-cnpj-validator": "1.0.3",
    "date-fns": "4.1.0",
    "dotenv": "16.4.7",
    "fastify": "5.5.0",
    "fastify-cookie": "5.7.0",
    "fastify-multer": "2.0.3",
    "fs-extra": "11.3.1",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "7.0.5",
    "sharp": "0.34.2",
    "zod": "4.1.5"
  }
}
