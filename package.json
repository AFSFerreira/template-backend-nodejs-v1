{
  "name": "astrobiologia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "license": "ISC",
  "author": "",
  "scripts": {
    "build": "tsup",
    "start:dev": "tsx watch --env-file=.env --no-deprecation src/server.ts",
    "start:prod": "node --enable-source-maps --env-file=.env dist/server.js",
    "start:prod:docker": "node --enable-source-maps dist/server.js",
    "ci:build": "rimraf dist && tsc --noEmit && tsup",
    "ci:lint": "npm run lint:fix:prisma && npm run lint:fix:src",
    "ci:format": "npm run format:prisma && npm run format:src",
    "lint:src": "eslint src/**/*.{js,ts,tsx,jsx}",
    "lint:prisma": "eslint prisma/**/*.{js,ts,tsx,jsx}",
    "lint:fix:src": "eslint --fix src/**/*.{js,ts,tsx,jsx}",
    "lint:fix:prisma": "eslint --fix prisma/**/*.{js,ts,tsx,jsx}",
    "format:src": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'src/**/*.{js,ts,tsx,jsx}'",
    "format:prisma": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'prisma/**/*.{js,ts,tsx,jsx}'",
    "husky": "husky",
    "husky:install": "husky install",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force --skip-seed",
    "db:seed": "prisma db seed",
    "db:reset:all": "rimraf prisma/migrations && npm run db:migrate:reset && npm run db:migrate:dev:default && prisma generate && npm run db:seed",
    "db:deploy": "prisma migrate deploy && prisma generate && npm run db:seed",
    "sentry:upload": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "20.0.0",
    "@eslint/js": "9.39.1",
    "@sentry/cli": "2.58.2",
    "@swc/core": "1.13.5",
    "@types/eslint__js": "8.42.3",
    "@types/fs-extra": "11.0.4",
    "@types/json2csv": "5.0.7",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "24.10.1",
    "@types/nodemailer": "7.0.3",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "@typescript-eslint/typescript-estree": "8.46.4",
    "commitlint": "20.1.0",
    "es-errors": "1.3.0",
    "eslint": "9.14.0",
    "eslint-compat-utils": "0.6.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-unicorn": "51.0.1",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "pino-pretty": "13.1.2",
    "prettier": "3.6.2",
    "prettier-plugin-prisma": "5.0.0",
    "prisma": "6.18.0",
    "rimraf": "6.1.0",
    "ts-node": "10.9.2",
    "tsup": "8.5.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.1.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.2.1",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "8.3.0",
    "@prisma/client": "6.19.0",
    "@sentry/node": "10.26.0",
    "@sentry/profiling-node": "10.26.0",
    "@tiptap/core": "3.10.5",
    "@tiptap/extension-image": "3.10.5",
    "@tiptap/extension-text-align": "3.10.5",
    "@tiptap/html": "3.10.5",
    "@tiptap/starter-kit": "3.10.5",
    "bcryptjs": "3.0.3",
    "cpf-cnpj-validator": "1.0.3",
    "date-fns": "4.1.0",
    "doi-utils": "2.0.6",
    "dotenv": "17.2.3",
    "fastify": "5.6.1",
    "fastify-cookie": "5.7.0",
    "fastify-multer": "2.0.3",
    "fs-extra": "11.3.2",
    "ioredis": "5.8.2",
    "json-stable-stringify": "1.3.0",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "9.0.2",
    "multer": "2.0.2",
    "node-cron": "4.2.1",
    "nodemailer": "7.0.10",
    "pino": "10.1.0",
    "sharp": "0.34.5",
    "uuid": "13.0.0",
    "zod": "4.1.12"
  }
}
