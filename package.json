{
  "name": "astrobiologia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "license": "ISC",
  "author": "",
  "scripts": {
    "build": "npm run db:generate && npm run generate:presenters && tsup",
    "generate:presenters": "npx tsx ./src/http/presenters/generate-imports.ts",
    "start:dev": "npm run generate:presenters && tsx watch --env-file=.env --no-deprecation src/server.ts",
    "start:prod": "node --enable-source-maps --env-file=.env dist/server.js",
    "start:prod:docker": "node --enable-source-maps dist/server.js",
    "ci:build": "rimraf dist; npm run db:generate && npm run generate:presenters && tsc && tsup",
    "ci:lint": "npm run lint:fix:prisma && npm run lint:fix:src",
    "ci:format": "npm run format:prisma && npm run format:src",
    "lint:src": "eslint src/**/*.{js,ts,tsx,jsx}",
    "lint:prisma": "eslint prisma/**/*.{js,ts,tsx,jsx}",
    "lint:fix:src": "eslint --fix src/**/*.{js,ts,tsx,jsx}",
    "lint:fix:prisma": "eslint --fix prisma/**/*.{js,ts,tsx,jsx}",
    "format:src": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'src/**/*.{js,ts,tsx,jsx}'",
    "format:prisma": "prettier --config .prettierrc.json --ignore-path .prettierignore --write 'prisma/**/*.{js,ts,tsx,jsx}'",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:reset": "npm run db:generate && npm run db:migrate:reset && npm run db:seed",
    "db:deploy": "prisma migrate deploy && prisma generate && npm run db:seed",
    "sentry:upload": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "20.2.0",
    "@commitlint/types": "20.2.0",
    "@eslint/js": "9.39.2",
    "@sentry/cli": "3.0.1",
    "@swc/core": "1.15.6",
    "@types/eslint__js": "9.14.0",
    "@types/fs-extra": "11.0.4",
    "@types/json2csv": "5.0.7",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "25.0.3",
    "@types/nodemailer": "7.0.4",
    "@types/pg": "8.16.0",
    "@typescript-eslint/eslint-plugin": "8.46.4",
    "@typescript-eslint/parser": "8.46.4",
    "@typescript-eslint/typescript-estree": "8.50.0",
    "commitlint": "20.2.0",
    "es-errors": "1.3.0",
    "eslint": "9.39.2",
    "eslint-compat-utils": "0.6.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unicorn": "51.0.1",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "pino-pretty": "13.1.3",
    "prettier": "3.7.4",
    "prettier-plugin-prisma": "5.0.0",
    "prisma": "7.2.0",
    "rimraf": "6.1.2",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.3.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "8.3.0",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "@sentry/node": "10.32.1",
    "@sentry/profiling-node": "10.32.1",
    "@tiptap/core": "3.14.0",
    "@tiptap/extension-image": "3.14.0",
    "@tiptap/extension-text-align": "3.14.0",
    "@tiptap/html": "3.14.0",
    "@tiptap/starter-kit": "3.14.0",
    "bcryptjs": "3.0.3",
    "cpf-cnpj-validator": "1.0.3",
    "cron-validator": "1.4.0",
    "date-fns": "4.1.0",
    "doi-utils": "2.0.6",
    "dotenv": "17.2.3",
