{
  "name": "astrobiologia-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "author": "",
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "build": "run-s ci:generate build:tsdown",
    "start:tsx:watch": "tsx watch --env-file=.env --no-deprecation src/server.ts",
    "start:dev": "run-s start:tsx:watch",
    "start:prod": "node --enable-source-maps --env-file=.env dist/server.mjs",
    "start:prod:docker": "node --enable-source-maps dist/server.mjs",
    "build:tsc": "tsc",
    "build:tsgo": "tsgo",
    "build:tsdown": "tsdown --config ./tsdown.config.ts",
    "lint:src:biome": "biome lint --write src",
    "lint:prisma:biome": "biome lint --write prisma",
    "format:src:biome": "biome format --write src",
    "format:prisma:biome": "biome format --write prisma",
    "check:src:biome": "biome check --write src",
    "check:prisma:biome": "biome check --write prisma",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:dev:default": "prisma migrate dev --name creating_database_models",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:reset": "run-s db:generate db:migrate:reset db:seed",
    "db:migrate-deploy": "prisma migrate deploy",
    "db:deploy": "run-s db:migrate-deploy db:generate db:seed",
    "ci:generate": "run-p db:generate",
    "ci:lint": "run-p check:prisma:biome check:src:biome",
    "ci:format": "run-p check:prisma:biome check:src:biome",
    "ci:build": "run-s ci:generate build:tsgo build:tsdown",
    "sentry:upload": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist",
    "test:load:local": "BASE_URL=http://localhost:3000 envsubst < ./load-tests/targets.local.txt | vegeta attack -duration=10s -rate=3 | vegeta report",
    "test:load:stg": "BASE_URL=https://api-astrobiologia.injunior.com.br envsubst < load-tests/targets.stg.txt | vegeta attack -duration=10s -rate=10 | vegeta report",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/config-conventional": "20.4.3",
    "@commitlint/types": "20.4.3",
    "@sentry/cli": "3.3.0",
    "@swc/core": "1.15.18",
    "@types/fs-extra": "11.0.4",
    "@types/html-minifier-terser": "7.0.2",
    "@types/html-to-text": "9.0.4",
    "@types/json2csv": "5.0.7",
    "@types/jsonwebtoken": "9.0.10",
    "@types/ms": "2.1.0",
    "@types/multer": "2.1.0",
    "@types/node": "25.4.0",
    "@types/nodemailer": "7.0.11",
    "@types/nunjucks": "3.2.6",
    "@types/pg": "8.18.0",
    "@types/ws": "8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "commitlint": "20.4.3",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "npm-run-all": "4.1.5",
    "pino-pretty": "13.1.3",
    "prisma": "7.4.2",
    "ts-node": "10.9.2",
    "tsdown": "0.21.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@fastify/compress": "8.3.1",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/multipart": "9.4.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/static": "9.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/websocket": "11.2.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@sentry/node": "10.42.0",
    "@sentry/profiling-node": "10.42.0",
    "@tiptap/core": "3.20.1",
    "@tiptap/extension-color": "3.20.1",
    "@tiptap/extension-image": "3.20.1",
    "@tiptap/extension-link": "3.20.1",
    "@tiptap/extension-text-align": "3.20.1",
    "@tiptap/extension-text-style": "3.20.1",
    "@tiptap/extension-underline": "3.20.1",
    "@tiptap/html": "3.20.1",
    "@tiptap/pm": "3.20.1",
    "@tiptap/starter-kit": "3.20.1",
    "argon2": "0.44.0",
    "bancos-brasileiros": "6.2.197",
    "bcryptjs": "3.0.3",
    "bullmq": "5.70.4",
    "cpf-cnpj-validator": "1.0.3",
    "cron-validator": "1.4.0",
    "csv-stringify": "6.6.0",
    "dayjs": "1.11.19",
    "doi-utils": "2.0.6",
    "dotenv": "17.3.1",
    "exceljs": "4.4.0",
    "fast-glob": "3.3.3",
    "fastify": "5.8.2",
    "fastify-type-provider-zod": "6.1.0",
    "fs-extra": "11.3.4",
    "html-minifier-terser": "7.2.0",
    "html-to-text": "9.0.5",
    "http-status-codes": "2.3.0",
    "ioredis": "5.10.0",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "9.0.3",
    "ms": "2.1.3",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.2",
    "nunjucks": "3.2.4",
    "orcid-utils": "1.2.3",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pix-utils-js": "1.0.8",
    "reflect-metadata": "0.2.2",
    "sharp": "0.34.5",
    "slash": "5.1.0",
    "tsyringe": "4.10.0",
    "url-join": "5.0.0",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  }
}
