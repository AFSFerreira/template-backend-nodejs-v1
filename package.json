    "ioredis": "5.8.2",
    "json2csv": "6.0.0-alpha.2",
    "jsonwebtoken": "9.0.3",
    "node-cron": "4.2.1",
    "nodemailer": "7.0.11",
    "orcid-utils": "1.2.3",
    "pg": "8.16.3",
    "pino": "10.1.0",
    "reflect-metadata": "0.2.2",
    "sharp": "0.34.5",
    "tsyringe": "4.10.0",
    "url-join": "5.0.0",
    "uuid": "13.0.0",
    "zod": "4.2.1"
  }
}
